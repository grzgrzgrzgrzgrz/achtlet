# Achtlet - Environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit a real .env file. The provided .gitignore already excludes it.

# ============================================================
# REQUIRED - Application security
# ============================================================

# Password that unlocks the Achtlet UI. Use something strong (8+ chars).
APP_PASSWORD=change-me-now

# Secret used to sign session cookies. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ============================================================
# OPTIONAL - n8n connection (can also be set via the UI)
# ============================================================

# URL of your n8n instance (without trailing slash).
# If set here, the UI config form becomes read-only for this value.
N8N_URL=https://your-n8n-instance.example.com

# n8n API key. Create one in n8n under Settings -> API.
# If set here, the UI config form becomes read-only for this value.
N8N_API_KEY=

# ============================================================
# OPTIONAL - Advanced configuration
# ============================================================

# IANA timezone for cron jobs (default: UTC).
# Examples: Europe/Berlin, America/New_York, Asia/Tokyo
TZ=UTC

# Custom backup directory (default: /app/backups inside the container).
# BACKUP_DIR=/custom/backup/path

# Directory for persisted Achtlet config when you configure the app via the UI.
# Defaults to /app/data in Docker and ./.data locally.
# DATA_DIR=/custom/data/path

# Number of backup archives to keep.
# BACKUP_KEEP_LAST=10

# Node environment - automatically set to "production" in Docker.
# NODE_ENV=development
